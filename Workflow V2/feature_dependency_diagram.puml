@startuml feature_dependency

' ── Quick view for human readers ──────────────────────────────
' Source of truth: feature_dependency_chain.md
' If stale, ask Claude to regenerate from that doc.
' ──────────────────────────────────────────────────────────────

skinparam componentStyle rectangle
skinparam defaultFontName Arial
skinparam defaultFontSize 12
skinparam backgroundColor #FFFFFF

skinparam component {
  BackgroundColor #DBEAFE
  BorderColor #3B82F6
  FontColor #1E3A5F
  FontStyle bold
}

skinparam package {
  BackgroundColor #F8FAFC
  BorderColor #CBD5E1
  FontColor #334155
  FontStyle bold
}

skinparam arrow {
  Color #475569
  FontColor #475569
  FontSize 10
}

' ── Legend ────────────────────────────────────────────────────
note as LEGEND
  ——————►  direct call
  - - - ►  event subscription
end note

' ══════════════════════════════════════════════════════════════
' FEATURES — top = foundation, bottom = highest level
' ══════════════════════════════════════════════════════════════

package "Commitment" {
  [getDefinition()] as COMMIT_getDef
  [getStateTransitionLog()] as COMMIT_getLog
  [getPortfolioSize()] as COMMIT_getSize
  [getInstances(from,to,id?)] as COMMIT_getInst
  [getCurrentInstance(id)] as COMMIT_getCurr
  [getInstanceForCommitmentOnDate(id,date)] as COMMIT_getByDate
  [updateLivePerformance(id,value)] as COMMIT_updatePerf
  [<<event>> CommitmentEvent.*] as EV_CommitEvent
  [<<event>> InstanceGeneratedEvent] as EV_InstGen
  [<<event>> InstanceClosedEvent] as EV_InstClosed
  [<<event>> WindowWarningDueEvent] as EV_Warning
}

package "Activity" {
  [recordEntry(id,value)] as ACT_record
  [getTotalLoggedForCommitmentOnDate(id,date)] as ACT_getTotal
  [getEntriesForCommitment(id,from,to)] as ACT_getEntries
  [<<event>> ActivityRecordedEvent] as EV_ActRecorded
}

package "Performance" {
  [getPerformanceForPeriod(from,to,id?)] as PERF_getPeriod
  [getDayScore(date)] as PERF_getDay
  [getCommitmentWeekScore(id,week)] as PERF_getWeek
  [getOverallWeekScore(week)] as PERF_getOverall
  [<<event>> PerformanceUpdatedEvent] as EV_PerfUpdated
}

package "Garment" {
}

package "Rewards" {
  [<<event>> CupEarnedEvent] as EV_Cup
  [<<event>> StreakMilestoneReachedEvent] as EV_Streak
}

package "Encouragement" {
}

package "Progression" {
  [<<event>> LevelReachedEvent] as EV_Level
  [<<event>> BonusThreadAwardedEvent] as EV_Bonus
}

package "Analytics" {
  [getAnalytics(...)] as ANALYTICS_get
}

package "AI Insights" {
}

package "User / Settings" {
  [getUserPreferences()] as USER_getPrefs
  [getTier()] as USER_getTier
}

' ══════════════════════════════════════════════════════════════
' DEPENDENCIES
' ══════════════════════════════════════════════════════════════

' ── Activity → Commitment ────────────────────────────────────
Activity ..> EV_CommitEvent : watches\nPermanentlyDeleted

' ── Performance → Commitment ─────────────────────────────────
Performance ..> EV_InstGen    : watches
Performance ..> EV_InstClosed : watches
Performance --> COMMIT_updatePerf       : calls
Performance --> COMMIT_getByDate        : calls
Performance --> COMMIT_getInst          : calls

' ── Performance → Activity ───────────────────────────────────
Performance ..> EV_ActRecorded          : watches
Performance --> ACT_getTotal            : calls

' ── Garment → Commitment ─────────────────────────────────────
Garment --> COMMIT_getDef               : calls

' ── Garment → Performance ────────────────────────────────────
Garment ..> EV_PerfUpdated             : watches
Garment --> PERF_getPeriod             : calls

' ── Rewards → Commitment ─────────────────────────────────────
Rewards --> COMMIT_getInst             : calls

' ── Rewards → Performance ────────────────────────────────────
Rewards ..> EV_PerfUpdated            : watches (isClosed)
Rewards --> PERF_getOverall           : calls

' ── Encouragement → Activity ─────────────────────────────────
Encouragement ..> EV_ActRecorded      : watches

' ── Encouragement → Performance ──────────────────────────────
Encouragement ..> EV_PerfUpdated      : watches (isClosed)
Encouragement --> PERF_getDay         : calls

' ── Encouragement → Rewards ──────────────────────────────────
Encouragement ..> EV_Cup              : watches

' ── Progression → Rewards ────────────────────────────────────
Progression ..> EV_Cup                : watches

' ── Analytics → Commitment ───────────────────────────────────
Analytics --> COMMIT_getInst          : calls

' ── Analytics → Activity ─────────────────────────────────────
Analytics --> ACT_getEntries          : calls

' ── Analytics → Performance ──────────────────────────────────
Analytics --> PERF_getPeriod          : calls

' ── AI Insights → Analytics ──────────────────────────────────
[AI Insights] --> ANALYTICS_get       : calls

' ── User / Settings (cross-cutting) ──────────────────────────
Commitment --> USER_getPrefs          : calls
Performance --> USER_getPrefs         : calls
Garment    --> USER_getTier           : calls

@enduml
